<% if (theme.curtain && theme.curtain.enable) { %>
<%- partial('_partials/curtain') %>
<% } %>
<% var defaultCover = url_for('/img/default-cover.svg'); %>
<% var authorAvatar = url_for((theme.author && theme.author.avatar) ? theme.author.avatar : '/img/avatar.svg'); %>
<% var authorName = (theme.author && theme.author.name) ? theme.author.name : (config.author || ''); %>
<link rel="stylesheet" href="<%- url_for('/css/home.css') %>">

<main class="home">
  <div class="list">
    <%/* ---- Pinned posts first ---- */%>
    <% site.posts.each(function(post) { %>
      <% if (post.pin) { %>
        <a href="<%- url_for(post.path) %>" class="card pin">
          <div class="card-cover">
            <img
              class="headimg"
              src="<%- url_for(post.headimg || '/img/default-cover.svg') %>"
              alt="<%= post.title || '' %>"
              onerror="this.onerror=null;this.src='<%- defaultCover %>'"
            >
            <% if (post.views) { %><span class="card-views">👁 <%= post.views %></span><% } %>
          </div>
          <div class="post">
            <h2 class="title">【置顶】<%= post.title || '' %></h2>
            <p class="excerpt">
              <%- strip_html(
                post.excerpt
                || post.description
                || truncate(strip_html(post.content || ''), {length: 80})
                || ''
              ) %>
            </p>
          </div>
        </a>
      <% } %>
    <% }) %>

    <%/* ---- Regular posts ---- */%>
    <% page.posts.each(function(post) { %>
      <% if (!post.pin) { %>
        <a href="<%- url_for(post.path) %>" class="card">
          <div class="card-cover">
            <img
              class="headimg"
              src="<%- url_for(post.headimg || '/img/default-cover.svg') %>"
              alt="<%= post.title || '' %>"
              onerror="this.onerror=null;this.src='<%- defaultCover %>'"
            >
            <% if (post.views) { %><span class="card-views">👁 <%= post.views %></span><% } %>
          </div>
          <div class="post">
            <h2 class="title"><%= post.title || '' %></h2>
            <p class="excerpt">
              <%- strip_html(
                post.excerpt
                || post.description
                || truncate(strip_html(post.content || ''), {length: 80})
                || ''
              ) %>
            </p>
          </div>
        </a>
      <% } %>
    <% }) %>
  </div>
</main>

<script src="<%- url_for('/js/waterfall.js') %>"></script>
